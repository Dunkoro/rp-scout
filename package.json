{
  "name": "rp-scout",
  "version": "1.0.0",
  "description": "A Vue 3 project using Vite and Axios with PWA capabilities",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview"
  },
  "dependencies": {
    "vue": "^3.0.0",
    "axios": "^0.21.1"
  },
  "devDependencies": {
    "vite": "^2.0.0",
    "@vite-pwa/plugin": "^0.11.0"
  },
  "pwa": {
    "name": "rp-scout",
    "short_name": "Scout",
    "description": "Vue 3 PWA",
    "icons": [
      {
        "src": "/icon-192.png",
        "sizes": "192x192",
        "type": "image/png"
      },
      {
        "src": "/icon-512.png",
        "sizes": "512x512",
        "type": "image/png"
      }
    ],
    "theme_color": "#ffffff",
    "background_color": "#121212",
    "display": "standalone"
  }
}
